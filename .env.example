AUTH_ROOT_PASSWORD=Interativa@2026
AUTH_LOGIN_MAX_ATTEMPTS=5
AUTH_LOGIN_DECAY_SECONDS=60

RECAPTCHA_V3_ENABLED=false
RECAPTCHA_V3_SITE_KEY=
